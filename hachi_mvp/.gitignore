.DS_Store

# Runtime / local env
.env
.venv/
venv/
__pycache__/
.pytest_cache/
*.pyc

# Python packaging / build
*.egg-info/
dist/
build/

# Local databases and locks
*.db
*.sqlite
*.sqlite3
*.lock

