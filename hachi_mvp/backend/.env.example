# Runtime
HACHI_ENV=dev
HACHI_HOST=127.0.0.1
HACHI_PORT=8008
HACHI_MOCK_MODE=false

# Data
SQLITE_PATH=./data/hachi_mvp.db
MILVUS_MODE=remote
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=hachi_chunks_768
WORKSPACE_PATH=./workspace

# Embedding (OpenAI-compatible)
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_PROVIDER=dashscope_multimodal
EMBEDDING_API_KEY=sk-your-dashscope-api-key
EMBEDDING_MODEL=tongyi-embedding-vision-flash-2026-03-06
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=5

# Router model (OpenAI-compatible, DeepSeek by default)
ROUTER_BASE_URL=https://api.deepseek.com
ROUTER_API_KEY=sk-your-deepseek-api-key
ROUTER_MODEL=deepseek-v4-flash

# Pure-text answer/skill model. If ANSWER_API_KEY is empty, ROUTER_API_KEY is reused.
ANSWER_BASE_URL=https://api.deepseek.com
ANSWER_API_KEY=
ANSWER_MODEL=deepseek-v4-flash

# Legacy router config fallback
GLM5_ROUTER_BASE_URL=
GLM5_ROUTER_API_KEY=
GLM5_ROUTER_MODEL=glm-5

# Screenshot multimodal model (Qwen)
QWEN_ANSWER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ANSWER_API_KEY=sk-your-dashscope-api-key
QWEN_ANSWER_MODEL=qwen3.5-plus

# Web search
TAVILY_API_KEY=

# Chunking / retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
DEFAULT_TOP_K=8
MIN_SCORE=0.2

# Memory policy
MEMORY_MAX_MESSAGES=12
MEMORY_MAX_TOKENS=2500

# Local reminders
HACHI_ENABLE_DESKTOP_NOTIFICATIONS=true
HACHI_ENABLE_MACOS_CALENDAR_REMINDERS=false
HACHI_MACOS_CALENDAR_NAME=Hachi
HACHI_MACOS_CALENDAR_EVENT_DURATION_MINUTES=15
REMINDER_POLL_INTERVAL_SECONDS=15
