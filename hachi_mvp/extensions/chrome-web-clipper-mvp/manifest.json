{
  "manifest_version": 3,
  "name": "Hachi 网页采集器",
  "description": "将选中文字、网页正文和可见截图采集到 Hachi 知识库。",
  "version": "0.1.0",
  "action": {
    "default_title": "Hachi 网页采集器",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "128": "icons/lumina-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
